---

---

<section class="relative bg-gradient-to-br from-primary via-purple-700 to-secondary overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-10 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent rounded-full blur-3xl"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 py-20 md:py-28 text-center">
    <span class="inline-block bg-white/15 text-white text-sm font-medium px-4 py-1.5 rounded-full mb-6 backdrop-blur-sm">
      Envíos a todo México — Kits originales garantizados
    </span>
    <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-6">
      Tu tienda de
      <span class="text-accent">Gunpla</span>
      <br />en México
    </h1>
    <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-8">
      Kits originales Bandai de todas las líneas: HG, MG, RG, PG y más.
      Arma, colecciona y exhibe los mejores mechas del universo Gundam.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/#productos"
        class="inline-flex items-center gap-2 bg-white text-primary font-bold px-8 py-3.5 rounded-xl hover:bg-gray-100 transition-colors text-sm"
      >
        Ver catálogo
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="/blog/guia-compra"
        class="inline-flex items-center gap-2 bg-white/10 text-white font-bold px-8 py-3.5 rounded-xl hover:bg-white/20 transition-colors backdrop-blur-sm text-sm border border-white/20"
      >
        Guía para principiantes
      </a>
    </div>
  </div>
</section>
