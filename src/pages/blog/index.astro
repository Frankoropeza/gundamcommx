---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — Guías y noticias Gunpla"
  description="Artículos, guías de compra y noticias sobre Gunpla en México."
>
  <section class="max-w-4xl mx-auto px-4 py-16">
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-secondary">Blog</h1>
      <p class="text-gray-500 mt-2">Guías, noticias y consejos para el mundo Gunpla</p>
    </div>

    {posts.length === 0 ? (
      <p class="text-gray-400 text-center py-12">Próximamente publicaremos contenido. ¡Vuelve pronto!</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}`}
            class="block group bg-white rounded-2xl border border-gray-100 p-6 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300"
          >
            <div class="flex items-center gap-3 text-sm text-gray-400 mb-2">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('es-MX', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <span>·</span>
              <span>{post.data.author}</span>
            </div>
            <h2 class="text-xl font-bold text-secondary group-hover:text-primary transition-colors mb-2">
              {post.data.title}
            </h2>
            <p class="text-gray-500 text-sm">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-3">
                {post.data.tags.map((tag) => (
                  <span class="text-xs bg-primary/10 text-primary px-2.5 py-0.5 rounded-full font-medium">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
