---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ProductCard from '@/components/ProductCard.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('productos');
const featuredProducts = allProducts
  .filter((p) => p.data.featured)
  .slice(0, 6);

const allCategories = await getCollection('categorias');

const benefits = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H21M3.375 14.25h-.375a3 3 0 013-3h.75M21 12.75h-1.5m0 0h-6.75M13.5 12.75V8.25m0 4.5l-3-3m3 3l3-3" /></svg>`,
    title: 'Envío a todo México',
    desc: 'Entrega segura con doble empaque protector a toda la República.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    title: 'Pago 100% seguro',
    desc: 'Tarjetas, transferencia y más métodos de pago protegidos.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>`,
    title: 'Kits 100% originales',
    desc: 'Solo vendemos kits Bandai originales con sello de garantía.',
  },
];

const gradeColors: Record<string, string> = {
  HG: 'bg-blue-500',
  MG: 'bg-purple-600',
  RG: 'bg-red-500',
  PG: 'bg-yellow-500',
  SD: 'bg-pink-500',
  Accesorios: 'bg-gray-600',
};
---

<BaseLayout
  title="Gundam Com MX — Tienda de Gunpla en México"
  description="Tienda online de kits Gunpla originales Bandai en México. HG, MG, RG, PG y más. Envíos a toda la República."
>
  <HeroSection />

  <!-- Productos Destacados -->
  <section id="productos" class="max-w-7xl mx-auto px-4 py-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-extrabold text-secondary">
        Productos destacados
      </h2>
      <p class="text-gray-500 mt-2">Los kits más populares de nuestra tienda</p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
      {featuredProducts.map((product) => (
        <ProductCard
          title={product.data.title}
          grade={product.data.grade}
          scale={product.data.scale}
          price={product.data.price}
          salePrice={product.data.salePrice}
          stock={product.data.stock}
          image={product.data.image}
          slug={product.id}
        />
      ))}
    </div>
  </section>

  <!-- Categorías -->
  <section id="categorias" class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-2xl md:text-3xl font-extrabold text-secondary">
          Compra por grado
        </h2>
        <p class="text-gray-500 mt-2">Encuentra el kit perfecto según tu nivel</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {allCategories.map((cat) => (
          <a
            href={`/#categorias`}
            class="group relative bg-gray-50 rounded-2xl p-6 text-center hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 hover:-translate-y-1 border border-gray-100"
          >
            <div class={`w-12 h-12 ${gradeColors[cat.data.slug.toUpperCase()] ?? gradeColors[cat.data.name.split(' ')[0]] ?? 'bg-primary'} rounded-xl flex items-center justify-center mx-auto mb-3`}>
              <span class="text-white font-extrabold text-sm">
                {cat.data.slug.toUpperCase()}
              </span>
            </div>
            <h3 class="font-bold text-secondary text-sm mb-1">{cat.data.name}</h3>
            <p class="text-xs text-gray-400 leading-snug">{cat.data.description.slice(0, 60)}...</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Beneficios -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {benefits.map((b) => (
        <div class="flex items-start gap-4 bg-white rounded-2xl p-6 border border-gray-100">
          <div class="flex-shrink-0 w-14 h-14 bg-primary/10 text-primary rounded-xl flex items-center justify-center">
            <Fragment set:html={b.icon} />
          </div>
          <div>
            <h3 class="font-bold text-secondary mb-1">{b.title}</h3>
            <p class="text-sm text-gray-500">{b.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-4">
        ¿Nuevo en el hobby?
      </h2>
      <p class="text-white/80 mb-8">
        Lee nuestra guía completa para elegir tu primer kit Gunpla y empieza a construir hoy.
      </p>
      <a
        href="/blog/guia-compra"
        class="inline-flex items-center gap-2 bg-white text-primary font-bold px-8 py-3.5 rounded-xl hover:bg-gray-100 transition-colors text-sm"
      >
        Leer la guía
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
